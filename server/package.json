{
  "name": "@memory-mcp-dashboard/server",
  "version": "0.1.0",
  "description": "HTTP server for memory-mcp-dashboard",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
