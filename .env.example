# Server
PORT=8787
HOST=127.0.0.1
DASHBOARD_TOKEN=

# Embedding provider — matches @aalokjha/mem-aj env vars
# transformersjs (default, zero-config) | openai | ollama | custom | local
EMBEDDING_PROVIDER=transformersjs
# EMBEDDING_URL=
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=
# EMBEDDING_MAX_TOKENS=

# Vector DB provider — matches @aalokjha/mem-aj env vars
# local (default, JSON file store at ~/.memory-mcp/) | qdrant
VECTORDB_PROVIDER=local
# VECTORDB_URL=
# VECTORDB_API_KEY=
VECTORDB_COLLECTION=memories
# QDRANT_URL=http://localhost:6333
